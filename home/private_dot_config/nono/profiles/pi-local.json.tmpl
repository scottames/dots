{{- includeTemplate "nono-local-profile" (dict
      "ctx" .
      "extends" "pi"
      "name" "pi-local"
      "version" "0.2.0"
      "description" "Pi with local workflow access on top of the registry-managed nolabs-ai/pi profile"
      "security" true
      "extraRead" (list
        "/proc"
        (joinPath .chezmoi.homeDir ".local/share/pi-extensions")
      )
      "extraReadFile" (list
        (joinPath .chezmoi.homeDir ".config/agents/AGENTS.md")
      )
) -}}
