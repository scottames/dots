{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "default_agent": "plan",
  "instructions": [
{{- $instructionsDir := joinPath .chezmoi.homeDir ".config/agents/instructions" -}}
{{- if stat $instructionsDir }}
{{- $instructionsFiles := output "find" "-L" $instructionsDir
      "-name" "*.md" "-type" "f" -}}
{{- $instructionsFiles = $instructionsFiles | trim | splitList "\n" | sortAlpha }}
{{- range $i, $f := $instructionsFiles }}
    "{{ $f }}"{{ if lt (add $i 1) (len $instructionsFiles) }},{{ end }}
{{- end }}
  {{ else }}{{ end -}}
],
  "mcp": {
    "tavily": {
      "type": "remote",
      "url": "https://mcp.tavily.com/mcp",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:TAVILY_API_KEY}"
      }
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    }
  },
  "small_model": "openai/gpt-5-mini",
  "permission": {
    "bash": {
      "*": "ask",
      "/bin/ls*": "allow",
      "/usr/bin/ls*": "allow",
      "bash {{ .chezmoi.homeDir }}/.opencode/skills/**": "allow",
      "cargo build*": "allow",
      "cargo check*": "allow",
      "cargo doc*": "allow",
      "cargo info*": "allow",
      "cargo run*": "allow",
      "cargo test*": "allow",
      "cat*": "allow",
      "command grep*": "allow",
      "command ls*": "allow",
      "command rg*": "allow",
      "date *": "allow",
      "diff *": "allow",
      "git branch*": "allow",
      "git diff*": "allow",
      "git log": "allow",
      "git log*": "allow",
      "git ls*": "allow",
      "git mv*": "allow",
      "git rev-parse*": "allow",
      "git show*": "allow",
      "git status": "allow",
      "git status*": "allow",
      "git worktree list*": "allow",
      "gh issue view*": "allow",
      "gh pr view*": "allow",
      "gh run view*": "allow",
      "gh release view*": "allow",
      "go build*": "allow",
      "go list*": "allow",
      "go mod tidy*": "allow",
      "go run*": "allow",
      "go test*": "allow",
      "grep *": "allow",
      "gt ls*": "allow",
      "helm get*": "allow",
      "helm history*": "allow",
      "helm lint*": "allow",
      "helm template*": "allow",
      "ls *": "allow",
      "kubectl desc*": "allow",
      "kubectl get*": "allow",
      "kubectl list*": "allow",
      "mise run *": "allow",
      "npm ci*": "allow",
      "npm run build*": "allow",
      "npm test*": "allow",
      "pytest *": "allow",
      "rg *": "allow",
      "pwd": "allow",
      "test -f*": "allow",
      "thts sync*": "allow",
      "tree *": "allow",
      "trunk check*": "allow",
      "trunk fmt*": "allow",
      "uv run pytest*": "allow",
      "wc *": "allow"
    },
    "doom_loop": "ask",
    "edit": "ask",
    "external_directory": {
      "*": "ask",
      "~/.cargo/registry/src**": "allow",
      "~/.config/opencode/skills/**": "allow"
    },
    "skill": {
      "*": "ask",
      "brainstorming": "allow",
      "ce:brainstorm": "allow",
      "ce:plan": "allow",
      "ce:review": "allow",
      "ce:work": "allow",
      "dispatching-parallel-agents": "allow",
      "document-review": "allow",
      "executing-plans": "allow",
      "git-commit": "allow",
      "requesting-code-review": "allow",
      "resolve-pr-feedback": "allow",
      "subagent-driven-development": "allow",
      "systematic-debugging": "allow",
      "test-driven-development": "allow",
      "thts*": "allow",
      "using-superpowers": "allow",
      "verification-before-completion": "allow",
      "writing-plans": "allow"
    },
    "webfetch": "ask",
    "websearch": "allow"
  },
  "agent": {
    "plan": {
      "permission": {
        "edit": "deny"
      }
    }
  },
  "server": {
    "hostname": "127.0.0.1",
    "mdns": false
  },
  "share": "disabled"
}
