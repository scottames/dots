if ! command -v mise >/dev/null 2>&1; then
  warn 'mise unavailable; skipping Herdr agent integrations'
  exit 0
fi

if ! mise which herdr >/dev/null 2>&1; then
  warn 'managed herdr unavailable; skipping agent integrations'
  exit 0
fi

agents=(pi omp claude codex copilot devin droid kimi opencode kilo hermes qodercli cursor mastracode)

for agent in "${agents[@]}"; do
  executable="${agent}"
  if [[ ${agent} == cursor ]]; then
    executable=cursor-agent
  fi

  if ! mise which "${executable}" >/dev/null 2>&1; then
    continue
  fi

  if [[ ${agent} == pi || ${agent} == omp ]]; then
    mkdir -p "{{ .chezmoi.homeDir }}/.${agent}/agent/extensions"
  fi

  if ! mise exec -- herdr integration install "${agent}"; then
    warn "failed to install Herdr ${agent} integration; continuing"
  fi
done

