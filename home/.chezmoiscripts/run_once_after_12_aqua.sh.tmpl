#!/usr/bin/env bash

set -eufo pipefail

echo '
 в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—   в–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—
в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—
в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘
в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–„в–„ в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘
в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘
в•ҡв•җв•қ  в•ҡв•җв•қ в•ҡв•җв•җв–Җв–Җв•җв•қ  в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•қ  в•ҡв•җв•қ
'

magenta='\033[0;35m'
cyan='\033[0;36m'
clear='\033[0m'

# deps, in case we're running in init
if [[ -f "${HOME}/.cargo/env" ]]; then
  . "${HOME}/.cargo/env"
fi
if ! command -v go &>/dev/null && command -v mise &>/dev/null; then
  eval "$(mise env --shell bash)"
fi

# renovate: datasource=github-releases depName=aquaproj/aqua
_aqua_latest_version=v2.57.1

# renovate: datasource=github-releases depName=aquaproj/aqua-installer
_aqua_installer_version=v4.0.4
_aqua_installer_sha256sum="acd21cbb06609dd9a701b0032ba4c21fa37b0e3b5cc4c9d721cc02f25ea33a28"

if command -v aqua; then
  _aqua_current="$(aqua -v | head -n1 | cut -d" " -f3 | sed "s/^/v/")"
else
  _aqua_current="none"
fi

printf "\n${cyan}рҹ’§ aqua${clear}\n---\n${magenta} - latest: %s\n - current: %s${clear}\n\n" "${_aqua_latest_version}" "${_aqua_current}"

if [[ ! $(command -v aqua) ]]; then
  # ensure AQUA vars are set
  function setenv() { export "$1=$2"; }

  DOTS="${DOTS:={{ .home.dots }}}"
  eval "$(grep -iP 'AQUA(?!.*GHTKN)' "${HOME}/.setenv")"

  pushd "$(mktemp -d)"
  _aqua_installer="aqua-installer"

  printf "\n${cyan}рҹ’§ aqua-installer version${clear}:${magenta} %s\n${clear}" "${_aqua_installer_version}"

  curl -sSfL "https://raw.githubusercontent.com/aquaproj/aqua-installer/${_aqua_installer_version}/aqua-installer" \
    -o "${_aqua_installer}"
  echo "${_aqua_installer_sha256sum}  ${_aqua_installer}" | sha256sum -c
  chmod +x "${_aqua_installer}"
  "./${_aqua_installer}"

  # ensure aqua is in path
  eval "$(grep -i AQUA <"${HOME}"/.bashrc)"

  popd
elif [[ "${_aqua_latest_version}" != "${_aqua_current}" ]]; then
  if [[ $(command -v op) ]]; then
    op run -- aqua update-aqua || GITHUB_TOKEN="" aqua update-aqua
  else
    GITHUB_TOKEN="" aqua update-aqua
  fi
else
  printf "\n${cyan}рҹ’§ ${magenta}%s${clear}\n\n" "пҖҢ aqua installed and up to date"
fi

printf "\n${cyan}рҹ’§ ${magenta}%s${clear}\n\n" "ensure all aqua packages installed"

# .config/aqua/aqua.yaml hash: {{ include "../aqua/aqua.yaml" | sha256sum }}
aqua install --all

printf "\n${cyan}рҹ’§ ${magenta}%s${clear}\n\n" "aqua done"

# vi: ft=bash
