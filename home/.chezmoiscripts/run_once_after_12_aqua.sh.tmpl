#!/usr/bin/env bash

set -eufo pipefail

echo '
 ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó
‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ
‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ‚ĖĄ‚ĖĄ ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ
‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ
‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ĖÄ‚ĖÄ‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ
'

magenta='\033[0;35m'
cyan='\033[0;36m'
red='\033[0;31m'
clear='\033[0m'

# deps, in case we're running in init
if [[ -f "${HOME}/.cargo/env" ]]; then
  # shellcheck source=/dev/null
  . "${HOME}/.cargo/env"
fi
if ! command -v go &>/dev/null && command -v mise &>/dev/null; then
  eval "$(mise env --shell bash)"
fi

# ensure AQUA vars are set, even when aqua itself is provided by mise
DOTS="${DOTS:={{ .home.dots }}}"
export AQUA_CONFIG_DIR="${AQUA_CONFIG_DIR:-${HOME}/.config/aquaproj-aqua}"
export AQUA_GLOBAL_CONFIG="${AQUA_GLOBAL_CONFIG:-${AQUA_CONFIG_DIR}/aqua.yaml}"
export AQUA_LOG_COLOR="${AQUA_LOG_COLOR:-always}"
export AQUA_PROGRESS_BAR="${AQUA_PROGRESS_BAR:-true}"
export AQUA_ROOT_DIR="${AQUA_ROOT_DIR:-${HOME}/.local/share/aquaproj-aqua/bin}"
AQUA_POLICY_CONFIG="${AQUA_POLICY_CONFIG:-}"

if [[ -f "${AQUA_CONFIG_DIR}/aqua-policy.yaml" ]]; then
  AQUA_POLICY_CONFIG="${AQUA_CONFIG_DIR}/aqua-policy.yaml"
fi
if [[ -f "${DOTS}/aqua/aqua-policy.yaml" ]]; then
  AQUA_POLICY_CONFIG="${AQUA_POLICY_CONFIG:+${AQUA_POLICY_CONFIG}:}${DOTS}/aqua/aqua-policy.yaml"
fi
if [[ -f "/var${AQUA_CONFIG_DIR}/aqua-policy.yaml" ]]; then
  AQUA_POLICY_CONFIG="${AQUA_POLICY_CONFIG:+${AQUA_POLICY_CONFIG}:}/var${AQUA_CONFIG_DIR}/aqua-policy.yaml"
fi
if [[ -n "${AQUA_POLICY_CONFIG}" ]]; then
  export AQUA_POLICY_CONFIG
fi

# renovate: datasource=github-releases depName=aquaproj/aqua
_aqua_latest_version=v2.59.0

# renovate: datasource=github-releases depName=aquaproj/aqua-installer
_aqua_installer_version=v4.0.4
_aqua_installer_sha256sum="acd21cbb06609dd9a701b0032ba4c21fa37b0e3b5cc4c9d721cc02f25ea33a28"

if command -v aqua &>/dev/null; then
  _aqua_current="$(aqua -v | head -n1 | cut -d" " -f3 | sed "s/^/v/")"
else
  _aqua_current="none"
fi

printf "\n${cyan}ūüíß aqua${clear}\n---\n${magenta} - latest: %s\n - current: %s${clear}\n\n" "${_aqua_latest_version}" "${_aqua_current}"

if ! command -v aqua &>/dev/null; then
  pushd "$(mktemp -d)"
  _aqua_installer="aqua-installer"

  printf "\n${cyan}ūüíß aqua-installer version${clear}:${magenta} %s\n${clear}" "${_aqua_installer_version}"

  curl -sSfL "https://raw.githubusercontent.com/aquaproj/aqua-installer/${_aqua_installer_version}/aqua-installer" \
    -o "${_aqua_installer}"
  echo "${_aqua_installer_sha256sum}  ${_aqua_installer}" | sha256sum -c
  chmod +x "${_aqua_installer}"
  "./${_aqua_installer}"

  # ensure aqua is in path
  export PATH="${AQUA_ROOT_DIR}:${AQUA_ROOT_DIR}/bin:${PATH}"
  if ! command -v aqua &>/dev/null; then
    printf "\n${red}ūüí• %s${clear}\n\n" "aqua installer completed, but aqua is not on PATH"
    exit 1
  fi

  popd
elif [[ "${_aqua_latest_version}" != "${_aqua_current}" ]]; then
  if command -v op &>/dev/null; then
    op run -- aqua update-aqua || GITHUB_TOKEN="" aqua update-aqua
  else
    GITHUB_TOKEN="" aqua update-aqua
  fi
else
  printf "\n${cyan}ūüíß ${magenta}%s${clear}\n\n" "ÔÄĆ aqua installed and up to date"
fi

printf "\n${cyan}ūüíß ${magenta}%s${clear}\n\n" "ensure all aqua packages installed"

# .config/aqua/aqua.yaml hash: {{ include "../aqua/aqua.yaml" | sha256sum }}
aqua install --all

printf "\n${cyan}ūüíß ${magenta}%s${clear}\n\n" "clean stale aqua bins and packages"

_aqua_root="$(aqua root-dir)"
_aqua_bin_dir="${_aqua_root}/bin"
_aqua_pkgs_dir="${_aqua_root}/pkgs"
_aqua_cleanup_dir="$(mktemp -d)"
_aqua_backup_bin_dir="${_aqua_cleanup_dir}/bin"
_aqua_backup_pkgs_dir="${_aqua_cleanup_dir}/pkgs"

mkdir -p "${_aqua_backup_bin_dir}" "${_aqua_backup_pkgs_dir}"

restore_aqua_cleanup() {
  mkdir -p "${_aqua_bin_dir}" "${_aqua_pkgs_dir}"

  set +f
  shopt -s nullglob
  for _aqua_backup in "${_aqua_backup_bin_dir}"/*; do
    _aqua_restore_target="${_aqua_bin_dir}/${_aqua_backup##*/}"
    rm -rf "${_aqua_restore_target}"
    mv "${_aqua_backup}" "${_aqua_restore_target}"
  done
  for _aqua_backup in "${_aqua_backup_pkgs_dir}"/*; do
    _aqua_restore_target="${_aqua_pkgs_dir}/${_aqua_backup##*/}"
    rm -rf "${_aqua_restore_target}"
    mv "${_aqua_backup}" "${_aqua_restore_target}"
  done
  shopt -u nullglob
  set -f
}

cleanup_aqua_on_error() {
  if restore_aqua_cleanup; then
    rm -rf "${_aqua_cleanup_dir:?}"
  else
    printf "\n${red}ūüí• %s${clear}\n\n" "aqua cleanup restore failed; backup retained at ${_aqua_cleanup_dir}"
  fi
}

trap cleanup_aqua_on_error ERR

if [[ -d "${_aqua_bin_dir}" ]]; then
  set +f
  shopt -s nullglob
  for _aqua_bin in "${_aqua_bin_dir}"/*; do
    _aqua_bin_name="${_aqua_bin##*/}"
    if [[ "${_aqua_bin_name}" == "aqua" ]]; then
      continue
    fi

    mv "${_aqua_bin}" "${_aqua_backup_bin_dir}/"
    printf "${magenta} - staged stale aqua bin: %s${clear}\n" "${_aqua_bin_name}"
  done
  shopt -u nullglob
  set -f
fi

if [[ -d "${_aqua_pkgs_dir}" ]]; then
  set +f
  shopt -s nullglob
  for _aqua_pkg in "${_aqua_pkgs_dir}"/*; do
    mv "${_aqua_pkg}" "${_aqua_backup_pkgs_dir}/"
  done
  shopt -u nullglob
  set -f
fi

if ! aqua install --all; then
  trap - ERR
  printf "\n${red}ūüí• %s${clear}\n\n" "aqua install failed; restoring staged aqua cleanup"
  if restore_aqua_cleanup; then
    rm -rf "${_aqua_cleanup_dir:?}"
  else
    printf "\n${red}ūüí• %s${clear}\n\n" "aqua cleanup restore failed; backup retained at ${_aqua_cleanup_dir}"
  fi
  exit 1
fi

trap - ERR
rm -rf "${_aqua_cleanup_dir:?}"

printf "\n${cyan}ūüíß ${magenta}%s${clear}\n\n" "aqua done"

