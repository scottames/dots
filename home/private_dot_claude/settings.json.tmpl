{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "alwaysThinkingEnabled": true,
  "enabledPlugins": {
{{- if lookPath "nono" }}
    "nono@nolabs-ai": true
{{- end }}
  },
  "env": {
    "DISABLE_AUTOUPDATER": "1"
  },
  "feedbackSurveyState": {
    "lastShownTime": 1754077213482
  },
  "fileSuggestion": {
    "command": "{{ .chezmoi.homeDir }}/.claude/scripts/file-suggestion.sh",
    "type": "command"
  },
{{- $thtsStart := joinPath .chezmoi.homeDir ".claude/hooks/thts-session-start.sh" -}}
{{- $thtsPrompt := joinPath .chezmoi.homeDir ".claude/hooks/thts-prompt-check.sh" -}}
{{- $herdrAgentState := joinPath .chezmoi.homeDir ".claude/hooks/herdr-agent-state.sh" -}}
{{- $sessionStart := list -}}
{{- if stat $thtsStart -}}
{{- $sessionStart = append $sessionStart (dict "hooks" (list (dict "command" $thtsStart "type" "command"))) -}}
{{- end -}}
{{- if stat $herdrAgentState -}}
{{- $sessionStart = append $sessionStart (dict "hooks" (list (dict "command" (printf "bash '%s' session" $herdrAgentState) "timeout" 10 "type" "command")) "matcher" "*") -}}
{{- end -}}
{{- $userPromptSubmit := list -}}
{{- if stat $thtsPrompt -}}
{{- $userPromptSubmit = append $userPromptSubmit (dict "hooks" (list (dict "command" $thtsPrompt "type" "command"))) -}}
{{- end }}
  "hooks": {
    "SessionStart": {{ $sessionStart | toPrettyJson | trimSuffix "\n" | replace "\n" "\n    " }},
    "UserPromptSubmit": {{ $userPromptSubmit | toPrettyJson | trimSuffix "\n" | replace "\n" "\n    " }}
  },
  "model": "opus",
  "permissions": {
    "allow": [
      "Bash(/bin/ls:*)",
      "Bash(/usr/bin/ls:*)",
      "Bash(cargo build:*)",
      "Bash(cargo check:*)",
      "Bash(cargo doc:*)",
      "Bash(cargo info:*)",
      "Bash(cargo run:*)",
      "Bash(cargo test:*)",
      "Bash(git mv:*)",
      "Bash(git show:*)",
      "Bash(go build:*)",
      "Bash(go mod tidy:*)",
      "Bash(go list:*)",
      "Bash(go run:*)",
      "Bash(go test:*)",
      "Bash(grep:*)",
      "Bash(command find:*)",
      "Bash(command grep:*)",
      "Bash(command ls:*)",
      "Bash(ls:*)",
      "Bash(thts sync:*)",
      "Bash(tree:*)",
      "Bash(trunk check:*)",
      "Bash(trunk fmt:*)",
      "Bash(wc:*)",
      "Read(~/.config/agents/*.md)",
      "Read(~/.config/agents/*/*.md)",
      "Read(thoughts/*)",
      "WebFetch(domain:crates.io)",
      "WebFetch(domain:docs.renovatebot.com)",
      "WebFetch(domain:docs.rs)",
      "WebFetch(domain:github.com)",
      "WebSearch"
    ]
  },
  "preferences": {
    "autoSave": true,
    "theme": "dark"
  },
  "statusLine": {
    "command": "{{ .chezmoi.homeDir }}/.claude/scripts/statusline.sh",
    "type": "command"
  }
}
