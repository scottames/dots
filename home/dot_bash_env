#!/usr/bin/env bash
# vi: ft=bash

# BASH_ENV is sourced by every non-interactive bash that inherits it. Keep this
# file silent and limited to PATH setup.

if [[ -z ${MISE_SHIMS_DIR-} ]]; then
  MISE_SHIMS_DIR="${HOME}/.local/share/mise/shims"
fi

_home_local_bin="${HOME}/.local/bin"

if [[ -d ${MISE_SHIMS_DIR} ]]; then
  _path_without_overrides=":${PATH-}:"
  _path_without_overrides=${_path_without_overrides//:${_home_local_bin}:/:}
  _path_without_overrides=${_path_without_overrides//:${MISE_SHIMS_DIR}:/:}
  _path_without_overrides=${_path_without_overrides#:}
  _path_without_overrides=${_path_without_overrides%:}

  if [[ -n ${_path_without_overrides} ]]; then
    export PATH="${_home_local_bin}:${MISE_SHIMS_DIR}:${_path_without_overrides}"
  else
    export PATH="${_home_local_bin}:${MISE_SHIMS_DIR}"
  fi

  unset _path_without_overrides
fi

unset _home_local_bin
