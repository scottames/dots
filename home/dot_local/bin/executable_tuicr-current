#!/usr/bin/env bash

# dirty worktree → tuicr -w
# existing PR    → tuicr pr <number>
# Graphite repo  → tuicr -r <merge-base-with-gt-parent>..HEAD
# normal repo    → tuicr -r <merge-base-with-default-branch>..HEAD
# fallback       → tuicr

set -euo pipefail

mode="${1:-auto}"

current_pr_number() {
  command -v gh >/dev/null 2>&1 || return 0
  gh pr view --json number -q .number 2>/dev/null || true
}

graphite_parent() {
  [[ ${GRAPHITE_ENABLED-} == "true" ]] || return 0
  command -v gt >/dev/null 2>&1 || return 0
  gt parent 2>/dev/null | head -n1 || true
}

default_branch_name() {
  if command -v gh >/dev/null 2>&1; then
    gh repo view --json defaultBranchRef -q '.defaultBranchRef.name' 2>/dev/null && return 0
  fi

  git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null |
    sed 's#^origin/##' &&
    return 0

  for branch in main master trunk develop; do
    if git show-ref --verify --quiet "refs/remotes/origin/${branch}"; then
      echo "${branch}"
      return 0
    fi
  done

  return 0
}

default_base_ref() {
  local branch
  branch="$(default_branch_name 2>/dev/null)"

  if [[ -n ${branch} ]]; then
    for remote in origin upstream; do
      if git rev-parse --verify --quiet "${remote}/${branch}" >/dev/null; then
        echo "${remote}/${branch}"
        return 0
      fi
    done

    if git rev-parse --verify --quiet "${branch}" >/dev/null; then
      echo "${branch}"
      return 0
    fi
  fi

  return 0
}

best_base_ref() {
  local parent
  parent="$(graphite_parent)"
  if [[ -n ${parent} ]]; then
    echo "${parent}"
    return 0
  fi

  default_base_ref
}

review_range() {
  local base merge_base
  base="$(best_base_ref)"

  if [[ -z ${base} ]]; then
    exec tuicr
  fi

  merge_base="$(git merge-base "${base}" HEAD 2>/dev/null || true)"
  if [[ -z ${merge_base} ]]; then
    exec tuicr -r "${base}..HEAD"
  fi

  exec tuicr -r "${merge_base}..HEAD"
}

review_pr() {
  local pr
  pr="$(current_pr_number)"
  if [[ -z ${pr} ]]; then
    echo "No GitHub PR found for current branch."
    exit 1
  fi

  exec tuicr pr "${pr}"
}

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  exec tuicr
fi

case "${mode}" in
auto)
  if ! git diff --quiet --ignore-submodules -- ||
    ! git diff --cached --quiet --ignore-submodules -- ||
    [[ -n "$(git ls-files --others --exclude-standard)" ]]; then
    exec tuicr -w
  fi

  pr="$(current_pr_number)"
  if [[ -n ${pr} ]]; then
    exec tuicr pr "${pr}"
  fi

  review_range
  ;;

wip)
  exec tuicr -w
  ;;

pr)
  review_pr
  ;;

range | branch)
  review_range
  ;;

selector | select)
  exec tuicr
  ;;

*)
  echo "usage: tuicr-current [auto|wip|pr|range|branch|selector]"
  exit 2
  ;;
esac
