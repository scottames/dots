#!/usr/bin/env bash

# Run Pi inside the pi-local Nono profile. The shared nono-with-local-path
# wrapper handles PATH plus the per-invocation Git worktree and Herdr socket
# grants; this wrapper adds only the two Pi-specific concerns:
# - A private, readable TMPDIR (Nono grants shared /tmp write-only, but Pi
#   extensions need to read back their own temporary files).
# - NONO_REJECT_OVERLAP, so the shared wrapper refuses any worktree/cwd grant
#   that would expose the Pi extension tree as writable.

set -eufo pipefail

export TMPDIR="${HOME}/.pi/agent/tmp"
mkdir -p "${TMPDIR}"
chmod 700 "${TMPDIR}"

export NONO_REJECT_OVERLAP="${HOME}/.local/share/pi-extensions"

exec nono-with-local-path wrap --profile pi-local --allow-cwd -- pi "$@"
