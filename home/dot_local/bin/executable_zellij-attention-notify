#!/usr/bin/env bash

# Bridge script for zellij-attention notifications.
# https://github.com/KiryuuLight/zellij-attention
#
# Why:
# - Provides one stable command for agent integrations to signal tab attention
#   in Zellij without duplicating pipe logic.
#
# What uses it:
# - Claude Code hooks in ~/.claude/settings.json (Notification, Stop)
# - OpenCode plugin ~/.config/opencode/plugins/zellij-attention.js
#
# Behavior:
# - Accepts one state: waiting|completed
# - Sends: zellij-attention::<state>::$ZELLIJ_PANE_ID via `zellij pipe --name`
# - Exits successfully when not in Zellij or when zellij is unavailable

set -euo pipefail

if [[ $# -ne 1 ]]; then
  printf 'usage: %s <waiting|completed>\n' "$0" >&2
  exit 2
fi

state="$1"
if [[ ${state} != "waiting" && ${state} != "completed" ]]; then
  printf 'invalid state: %s\n' "${state}" >&2
  exit 2
fi

if [[ -z ${ZELLIJ_PANE_ID-} ]]; then
  exit 0
fi

if ! command -v zellij >/dev/null 2>&1; then
  exit 0
fi

zellij pipe --name "zellij-attention::${state}::${ZELLIJ_PANE_ID}" >/dev/null 2>&1 || true
